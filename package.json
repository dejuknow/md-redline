{
  "name": "md-redline",
  "description": "Local inline review for markdown files with agent-friendly comment markers.",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/dejuknow/md-redline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dejuknow/md-redline.git"
  },
  "bugs": {
    "url": "https://github.com/dejuknow/md-redline/issues"
  },
  "keywords": [
    "markdown",
    "review",
    "comments",
    "documentation",
    "agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mdr": "bin/md-redline",
    "md-redline": "bin/md-redline"
  },
  "files": [
    "bin/",
    "dist/",
    "public/",
    "server/",
    "src/",
    "index.html",
    "README.md",
    "LICENSE",
    "package.json",
    "tsconfig.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "vite.config.ts"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx server/index.ts\" \"vite\"",
    "dev:server": "tsx server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run build && npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "eval": "tsx eval/runner.ts",
    "eval:dry": "tsx eval/runner.ts --dry-run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.8",
    "mermaid": "^11.13.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
