#!/usr/bin/env bash
set -euo pipefail

# md-review — open a markdown file or folder in md-review for reviewing
# Usage: md-review <file.md>
#        md-review <directory>
#        md-review              (opens the app with no file pre-loaded)

# Resolve symlinks (e.g. when invoked via npm-linked `mdr`)
SCRIPT="$0"
if [[ -L "$SCRIPT" ]]; then
  SCRIPT="$(readlink "$SCRIPT")"
  # Handle relative symlinks
  [[ "$SCRIPT" != /* ]] && SCRIPT="$(dirname "$0")/$SCRIPT"
fi
APP_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
SERVER_PORT=3001
CLIENT_PORT=5173

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: md-review [file.md | directory]"
  echo "Opens a markdown file or folder in md-review for inline commenting."
  echo "Starts the app automatically if it's not already running."
  exit 0
fi

# Resolve the path — supports both files and directories
FILE=""
DIR=""
if [[ -n "${1:-}" ]]; then
  if [[ -d "$1" ]]; then
    DIR="$(cd "$1" && pwd)"
  elif [[ -f "$1" ]]; then
    FILE="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
  else
    echo "Error: not found: $1" >&2
    exit 1
  fi
fi

# Check if the server is already running
server_running() {
  curl -sf "http://localhost:${SERVER_PORT}/api/config" >/dev/null 2>&1
}

if ! server_running; then
  echo "Starting md-review..."
  cd "$APP_DIR"
  npm run dev >/dev/null 2>&1 &
  APP_PID=$!

  # Wait up to 15 seconds for the server
  for i in $(seq 1 30); do
    if server_running; then
      break
    fi
    if ! kill -0 "$APP_PID" 2>/dev/null; then
      echo "Error: app failed to start. Run 'npm run dev' manually for details." >&2
      exit 1
    fi
    sleep 0.5
  done

  if ! server_running; then
    echo "Error: server did not start within 15 seconds." >&2
    exit 1
  fi
  echo "md-review is running."
fi

# Build the URL
URL="http://localhost:${CLIENT_PORT}"
if [[ -n "$FILE" ]]; then
  ENCODED=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "$FILE")
  URL="${URL}?file=${ENCODED}"
elif [[ -n "$DIR" ]]; then
  ENCODED=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "$DIR")
  URL="${URL}?dir=${ENCODED}"
fi

# Open in the default browser
open "$URL" 2>/dev/null || xdg-open "$URL" 2>/dev/null || echo "Open in your browser: $URL"
